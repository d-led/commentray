{
  "name": "@commentray/core",
  "version": "0.3.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Commentray models, validation, SCM adapters, and staleness helpers",
  "license": "MPL-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./block-scroll-pickers": {
      "types": "./dist/block-scroll-pickers.d.ts",
      "import": "./dist/block-scroll-pickers.js"
    },
    "./static-browse-path": {
      "types": "./dist/commentray-static-browse-path.d.ts",
      "import": "./dist/commentray-static-browse-path.js"
    },
    "./buffering-flow-synchronizer": {
      "types": "./dist/buffering-flow-synchronizer.d.ts",
      "import": "./dist/buffering-flow-synchronizer.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "approvals": "^7.3.0"
  }
}
