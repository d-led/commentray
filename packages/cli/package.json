{
  "name": "commentray",
  "version": "0.2.1",
  "publishConfig": {
    "access": "public"
  },
  "description": "Commentray command-line interface. Run with npx commentray; npx commentray --help prints Usage: commentray [options] [command].",
  "license": "MPL-2.0",
  "type": "module",
  "bin": {
    "commentray": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "build:bundle": "npm run build && node ./esbuild.cli.mjs",
    "clean": "rm -rf dist",
    "commentray": "node ./dist/cli.js"
  },
  "dependencies": {
    "@commentray/code-commentray-static": "0.2.1",
    "@commentray/core": "0.2.1",
    "@commentray/render": "0.2.1",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "serve-handler": "^6.1.7"
  },
  "devDependencies": {
    "@types/serve-handler": "^6.1.4",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "postject": "^1.0.0-alpha.6"
  }
}
