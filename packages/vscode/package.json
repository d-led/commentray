{
  "name": "commentray-vscode",
  "displayName": "Commentray",
  "description": "Side-by-side authoring for Commentray markdown tracks",
  "version": "0.0.8",
  "publisher": "d-led",
  "private": true,
  "license": "MPL-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-led/commentray.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/d-led/commentray#readme",
  "bugs": {
    "url": "https://github.com/d-led/commentray/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:commentray.openSideBySide",
    "onCommand:commentray.openCommentrayAngle",
    "onCommand:commentray.addAngleDefinition",
    "onCommand:commentray.startBlockFromSelection",
    "onCommand:commentray.openCommentrayPreview",
    "onCommand:commentray.validateWorkspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentray.openSideBySide",
        "title": "Commentray: Open paired markdown beside editor"
      },
      {
        "command": "commentray.openCommentrayAngle",
        "title": "Commentray: Open paired markdown beside editor (choose angle)"
      },
      {
        "command": "commentray.addAngleDefinition",
        "title": "Commentray: Add angle to project…"
      },
      {
        "command": "commentray.startBlockFromSelection",
        "title": "Commentray: Add commentary block from selection"
      },
      {
        "command": "commentray.openCommentrayPreview",
        "title": "Commentray: Open Markdown preview for paired file"
      },
      {
        "command": "commentray.validateWorkspace",
        "title": "Commentray: Validate workspace"
      }
    ],
    "keybindings": [
      {
        "command": "commentray.startBlockFromSelection",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "commentray.openSideBySide",
          "group": "commentray@1",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.openCommentrayAngle",
          "group": "commentray@1b",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.addAngleDefinition",
          "group": "commentray@1c",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.startBlockFromSelection",
          "group": "commentray@2",
          "when": "editorTextFocus && !editorReadonly"
        }
      ]
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./esbuild.extension.mjs",
    "clean": "rm -rf dist",
    "test:vscode": "tsc -p tsconfig.tests.json && vscode-test"
  },
  "dependencies": {
    "@commentray/core": "0.0.8"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5"
  }
}
