{
  "name": "commentary-vscode",
  "displayName": "Commentary",
  "description": "Side-by-side authoring for Commentary markdown tracks",
  "version": "0.0.1",
  "publisher": "commentary",
  "private": true,
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:commentary.openSideBySide",
    "onCommand:commentary.openCommentaryPreview",
    "onCommand:commentary.validateWorkspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentary.openSideBySide",
        "title": "Commentary: Open commentary beside source"
      },
      {
        "command": "commentary.openCommentaryPreview",
        "title": "Commentary: Open Markdown preview for commentary file"
      },
      {
        "command": "commentary.validateWorkspace",
        "title": "Commentary: Validate workspace metadata"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commentary/core": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.96.0"
  }
}
