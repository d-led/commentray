{
  "name": "commentray-vscode",
  "displayName": "Commentray",
  "description": "Side-by-side authoring for Commentray markdown tracks",
  "version": "0.0.1",
  "publisher": "d-led",
  "private": true,
  "license": "MPL-2.0",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:commentray.openSideBySide",
    "onCommand:commentray.openCommentrayPreview",
    "onCommand:commentray.validateWorkspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "commentray.openSideBySide",
        "title": "Commentray: Open commentray beside source"
      },
      {
        "command": "commentray.openCommentrayPreview",
        "title": "Commentray: Open Markdown preview for commentray file"
      },
      {
        "command": "commentray.validateWorkspace",
        "title": "Commentray: Validate workspace metadata"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commentray/core": "0.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/vscode": "^1.96.0"
  }
}
