{
  "name": "commentray-vscode",
  "displayName": "Commentray",
  "description": "Side-by-side authoring for Commentray markdown tracks",
  "version": "0.3.1",
  "publisher": "d-led",
  "private": true,
  "license": "MPL-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/d-led/commentray.git",
    "directory": "packages/vscode"
  },
  "homepage": "https://github.com/d-led/commentray#readme",
  "bugs": {
    "url": "https://github.com/d-led/commentray/issues"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:commentray.openSideBySide",
    "onCommand:commentray.openCommentrayAngle",
    "onCommand:commentray.addAngleDefinition",
    "onCommand:commentray.startBlockFromSelection",
    "onCommand:commentray.openCommentrayPreview",
    "onCommand:commentray.openRenderedPreview",
    "onCommand:commentray.openRenderedPreviewChooseAngle",
    "onCommand:commentray.validateWorkspace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Commentray",
      "properties": {
        "commentray.scrollSync.enabled": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, scrolling the source editor updates the paired commentray editor (and vice versa), using block anchors when available. Reload or reopen the pair after changing this setting."
        }
      }
    },
    "commands": [
      {
        "command": "commentray.openSideBySide",
        "title": "Open paired markdown beside editor",
        "category": "Commentray"
      },
      {
        "command": "commentray.openCommentrayAngle",
        "title": "Open paired markdown (choose angle)",
        "category": "Commentray"
      },
      {
        "command": "commentray.addAngleDefinition",
        "title": "Add angle to project…",
        "category": "Commentray"
      },
      {
        "command": "commentray.startBlockFromSelection",
        "title": "Add commentary block from selection",
        "category": "Commentray"
      },
      {
        "command": "commentray.openCommentrayPreview",
        "title": "Open Markdown preview for paired file",
        "category": "Commentray"
      },
      {
        "command": "commentray.openRenderedPreview",
        "title": "Open rendered Commentray preview (default angle)",
        "category": "Commentray"
      },
      {
        "command": "commentray.openRenderedPreviewChooseAngle",
        "title": "Open rendered Commentray preview (choose angle)…",
        "category": "Commentray"
      },
      {
        "command": "commentray.validateWorkspace",
        "title": "Validate workspace",
        "category": "Commentray"
      }
    ],
    "keybindings": [
      {
        "command": "commentray.openSideBySide",
        "key": "ctrl+alt+o",
        "mac": "cmd+alt+o",
        "when": "editorTextFocus"
      },
      {
        "command": "commentray.startBlockFromSelection",
        "key": "ctrl+alt+k",
        "mac": "cmd+alt+k",
        "when": "editorTextFocus && !editorReadonly"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "commentray.openSideBySide",
          "group": "commentray@1",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.openCommentrayAngle",
          "group": "commentray@1b",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.openRenderedPreview",
          "group": "commentray@1d",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.openRenderedPreviewChooseAngle",
          "group": "commentray@1e",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.addAngleDefinition",
          "group": "commentray@1c",
          "when": "editorTextFocus"
        },
        {
          "command": "commentray.startBlockFromSelection",
          "group": "commentray@2",
          "when": "editorTextFocus && !editorReadonly"
        }
      ],
      "explorer/context": [
        {
          "command": "commentray.openSideBySide",
          "group": "commentray@1",
          "when": "resourceScheme == file"
        }
      ]
    },
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/commentray-markdown.code-snippets"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node ./esbuild.extension.mjs",
    "clean": "rm -rf dist",
    "test:vscode": "tsc -p tsconfig.tests.json && vscode-test"
  },
  "dependencies": {
    "@commentray/core": "0.3.1",
    "@commentray/render": "0.3.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "1.95.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "mocha": "^11.7.5"
  }
}
