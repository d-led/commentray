{
  "name": "@commentray/render",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Markdown + syntax highlighting rendering for Commentray",
  "license": "MPL-2.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node esbuild-code-browser-client.mjs && node copy-static-assets.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@commentray/core": "0.1.0",
    "@m31coding/fuzzy-search": "^2.0.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0"
  }
}
