{
  "name": "@commentray/code-commentray-static",
  "version": "0.0.7",
  "description": "Build static HTML pages for code + Commentray (resizable panes, wrap toggle)",
  "license": "MPL-2.0",
  "type": "module",
  "main": "./dist/build.js",
  "types": "./dist/build.d.ts",
  "exports": {
    ".": {
      "types": "./dist/build.d.ts",
      "import": "./dist/build.js"
    },
    "./github-pages-site": {
      "types": "./dist/github-pages-site.d.ts",
      "import": "./dist/github-pages-site.js"
    }
  },
  "files": [
    "dist",
    "fixtures",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "site": "node ./dist/cli.js"
  },
  "dependencies": {
    "@commentray/core": "0.0.7",
    "@commentray/render": "0.0.7",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  }
}
